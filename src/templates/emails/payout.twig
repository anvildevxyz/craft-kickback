{% extends 'kickback/emails/_base' %}

{% set title = 'Payout Processed'|t('kickback') %}

{% block content %}
    <h1 style="margin: 0 0 16px; font-size: 22px; font-weight: 600; color: #1a1a1a;">{{ 'Payout Processed'|t('kickback') }}</h1>
    <p style="margin: 0 0 16px; font-size: 15px;">{{ 'email.greeting'|t('kickback', { name: name }) }}</p>
    <p style="margin: 0 0 16px; font-size: 15px;">{{ 'email.payout.body'|t('kickback', { amount: amount, method: method }) }}</p>
    <p style="margin: 0; font-size: 15px;">{{ 'Thanks for being a great affiliate!'|t('kickback') }}</p>
{% endblock %}
