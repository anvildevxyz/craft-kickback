{% extends 'kickback/emails/_base' %}

{% set title = 'Application Update'|t('kickback') %}

{% block content %}
    <h1 style="margin: 0 0 16px; font-size: 22px; font-weight: 600; color: #1a1a1a;">{{ 'Application Update'|t('kickback') }}</h1>
    <p style="margin: 0 0 16px; font-size: 15px;">{{ 'email.greeting'|t('kickback', { name: name }) }}</p>
    <p style="margin: 0 0 16px; font-size: 15px;">{{ 'email.rejection.body'|t('kickback') }}</p>
    <p style="margin: 0; font-size: 15px;">{{ 'If you have questions, please contact us.'|t('kickback') }}</p>
{% endblock %}
