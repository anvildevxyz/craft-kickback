{% extends "kickback/portal/_layout" %}
{% set portalBase = '/' ~ settings.currentSitePortalPath %}

{% set activeNav = 'dashboard' %}

{% block title %}Dashboard{% endblock %}

{% block content %}
    <h1>Dashboard</h1>

    <div class="kb-stats">
        <div class="kb-stat-card">
            <div class="kb-stat-label">Total Clicks</div>
            <div class="kb-stat-value">{{ clickCount|number_format(0) }}</div>
        </div>
        <div class="kb-stat-card">
            <div class="kb-stat-label">Total Referrals</div>
            <div class="kb-stat-value">{{ affiliate.lifetimeReferrals|number_format(0) }}</div>
        </div>
        <div class="kb-stat-card">
            <div class="kb-stat-label">Lifetime Earnings</div>
            <div class="kb-stat-value">{{ affiliate.lifetimeEarnings|currency(craft.kickback.currency) }}</div>
        </div>
        <div class="kb-stat-card">
            <div class="kb-stat-label">Pending Balance</div>
            <div class="kb-stat-value">{{ affiliate.pendingBalance|currency(craft.kickback.currency) }}</div>
        </div>
    </div>

    <div class="kb-table-wrap" style="margin-bottom: 1.5rem;">
        <div class="kb-table-header">Referral Link</div>
        <div class="kb-table-wrap__body">
            <div class="kb-link-box">
                <input type="text" id="kb-referral-url" value="{{ affiliate.getReferralUrl() }}" readonly>
                <button type="button" class="kb-btn kb-btn-primary" onclick="kbCopyToClipboard('kb-referral-url', this)">Copy</button>
            </div>
        </div>
    </div>

    <div class="kb-table-wrap">
        <div class="kb-table-header">Recent Referrals</div>
        {% if recentReferrals|length > 0 %}
            <table class="kb-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Order Subtotal</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    {% for referral in recentReferrals %}
                        <tr>
                            <td>{{ referral.dateCreated|date('M j, Y') }}</td>
                            <td>{{ referral.orderSubtotal|currency(craft.kickback.currency) }}</td>
                            <td><span class="kb-badge kb-badge-{{ referral.status }}">{{ referral.status|capitalize }}</span></td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% else %}
            <div class="kb-empty">No referrals yet.</div>
        {% endif %}
        {% if totalReferralCount > 5 %}
            <div class="kb-table-wrap__footer">
                <a href="{{ portalBase }}/referrals" class="kb-link kb-link--small">View all referrals</a>
            </div>
        {% endif %}
    </div>

    <div class="kb-table-wrap">
        <div class="kb-table-header">Recent Commissions</div>
        {% if recentCommissions|length > 0 %}
            <table class="kb-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Amount</th>
                        <th>Rate</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    {% for commission in recentCommissions %}
                        <tr>
                            <td>{{ commission.dateCreated|date('M j, Y') }}</td>
                            <td>{{ commission.amount|currency(craft.kickback.currency) }}</td>
                            <td>
                                {% if commission.rateType == 'percentage' %}
                                    {{ commission.rate }}%
                                {% else %}
                                    {{ commission.rate|currency(craft.kickback.currency) }}
                                {% endif %}
                            </td>
                            <td><span class="kb-badge kb-badge-{{ commission.status }}">{{ commission.status|capitalize }}</span></td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% else %}
            <div class="kb-empty">No commissions yet.</div>
        {% endif %}
        {% if totalCommissionCount > 5 %}
            <div class="kb-table-wrap__footer">
                <a href="{{ portalBase }}/commissions" class="kb-link kb-link--small">View all commissions</a>
            </div>
        {% endif %}
    </div>
{% endblock %}

{% block scripts %}
    <script>
        function kbCopyToClipboard(inputId, btn) {
            var input = document.getElementById(inputId);
            navigator.clipboard.writeText(input.value).then(function() {
                var original = btn.textContent;
                btn.textContent = 'Copied!';
                setTimeout(function() {
                    btn.textContent = original;
                }, 2000);
            });
        }
    </script>
{% endblock %}
