{% extends '_layouts/cp' %}
{% set title = 'nav.reports'|t('kickback') %}
{% set selectedSubnavItem = 'reports' %}

{% set currency = craft.kickback.currency %}

{% block actionButton %}
    <a href="{{ url('kickback/reports/export', { startDate: startDate, endDate: endDate }) }}" class="btn">{{ 'Export CSV'|t('kickback') }}</a>
{% endblock %}

{% block content %}
    {% do view.registerAssetBundle('anvildev\\craftkickback\\assets\\cp\\CpAssetBundle') %}
    {% do view.registerJsFile('https://cdn.jsdelivr.net/npm/chart.js') %}

    <div class="kb-page">

        {# ── Date Range Filter ───────────────────── #}
        <div class="kb-date-filter">
            <form method="get" action="{{ url('kickback/reports') }}" style="display: contents;">
                <div class="field" style="margin: 0;">
                    <div class="heading"><label for="startDate">{{ 'Start Date'|t('kickback') }}</label></div>
                    <div class="input"><input type="date" id="startDate" name="startDate" value="{{ startDate ?? '' }}" class="text"></div>
                </div>
                <div class="field" style="margin: 0;">
                    <div class="heading"><label for="endDate">{{ 'End Date'|t('kickback') }}</label></div>
                    <div class="input"><input type="date" id="endDate" name="endDate" value="{{ endDate ?? '' }}" class="text"></div>
                </div>
                <button type="submit" class="btn submit">{{ 'Filter'|t('kickback') }}</button>
            </form>
            <div class="kb-date-presets">
                {% set presets = {
                    thisMonth: 'This Month'|t('kickback'),
                    lastMonth: 'Last Month'|t('kickback'),
                    last30: 'Last 30 Days'|t('kickback'),
                    thisYear: 'This Year'|t('kickback'),
                    allTime: 'All Time'|t('kickback'),
                } %}
                {% for key, label in presets %}
                    <a href="{{ url('kickback/reports', { preset: key }) }}"
                       class="kb-filter {{ (preset == key or (key == 'allTime' and preset is null and startDate is null and endDate is null)) ? 'is-active' }}">
                        {{ label }}
                    </a>
                {% endfor %}
            </div>
        </div>

        {# ── Stat Cards ──────────────────────────── #}
        <div class="kb-metrics">
            <div class="kb-metric kb-metric--teal">
                <div class="kb-metric__header">
                    <span class="kb-metric__label">{{ 'Total Affiliates'|t('kickback') }}</span>
                    <span class="kb-metric__icon">
                        <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    </span>
                </div>
                <div class="kb-metric__value">{{ stats.totalAffiliates }}</div>
                <div class="kb-metric__sub">{{ stats.activeAffiliates }} {{ 'active'|t('kickback') }}</div>
            </div>

            <div class="kb-metric kb-metric--violet">
                <div class="kb-metric__header">
                    <span class="kb-metric__label">{{ 'dashboard.totalReferrals'|t('kickback') }}</span>
                    <span class="kb-metric__icon">
                        <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
                    </span>
                </div>
                <div class="kb-metric__value">{{ stats.totalReferrals }}</div>
                <div class="kb-metric__sub">{{ stats.approvedReferrals }} {{ 'approved'|t('kickback') }}</div>
            </div>

            <div class="kb-metric kb-metric--emerald">
                <div class="kb-metric__header">
                    <span class="kb-metric__label">{{ 'dashboard.totalCommissions'|t('kickback') }}</span>
                    <span class="kb-metric__icon">
                        <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                    </span>
                </div>
                <div class="kb-metric__value">{{ stats.totalCommissions|currency(currency) }}</div>
                <div class="kb-metric__sub">{{ stats.pendingCommissions|currency(currency) }} {{ 'pending'|t('kickback') }}</div>
            </div>

            <div class="kb-metric kb-metric--blue">
                <div class="kb-metric__header">
                    <span class="kb-metric__label">{{ 'dashboard.totalClicks'|t('kickback') }}</span>
                    <span class="kb-metric__icon">
                        <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4l7.07 17 2.51-7.39L21 11.07z"/><path d="M15 15l5 5"/></svg>
                    </span>
                </div>
                <div class="kb-metric__value">{{ stats.totalClicks|number_format }}</div>
            </div>

            <div class="kb-metric kb-metric--amber">
                <div class="kb-metric__header">
                    <span class="kb-metric__label">{{ 'Total Payouts'|t('kickback') }}</span>
                    <span class="kb-metric__icon">
                        <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
                    </span>
                </div>
                <div class="kb-metric__value">{{ stats.totalPayouts|currency(currency) }}</div>
                <div class="kb-metric__sub">{{ 'completed'|t('kickback') }}</div>
            </div>
        </div>

        {# ── Charts ──────────────────────────────── #}
        <div class="kb-grid-2" style="margin-block-end: 1.5rem;">
            <div class="kb-chart-wrap" style="animation-delay: 0.25s;">
                <div class="kb-chart-header">
                    <h2 class="kb-chart-title">{{ 'Daily Commissions'|t('kickback') }}</h2>
                </div>
                <div class="kb-chart-container" style="height: 220px;">
                    <canvas id="kb-commissions-chart"></canvas>
                </div>
            </div>
            <div class="kb-chart-wrap" style="animation-delay: 0.3s;">
                <div class="kb-chart-header">
                    <h2 class="kb-chart-title">{{ 'Daily Referrals'|t('kickback') }}</h2>
                </div>
                <div class="kb-chart-container" style="height: 220px;">
                    <canvas id="kb-referrals-chart"></canvas>
                </div>
            </div>
        </div>

        {% js %}
            (function() {
                var commissionsData = {{ dailyCommissions|json_encode|raw }};
                var referralsData = {{ dailyReferrals|json_encode|raw }};
                var isDark = document.documentElement.dataset.colorScheme === 'dark';
                var gridColor = isDark ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.05)';
                var tickColor = isDark ? 'rgba(255,255,255,0.4)' : 'rgba(0,0,0,0.4)';

                function fmtDate(label) {
                    var d = new Date(label + 'T00:00:00');
                    return d.toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
                }

                var baseOpts = {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: { intersect: false, mode: 'index' },
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: isDark ? '#334155' : '#1e293b',
                            titleColor: '#e2e8f0',
                            bodyColor: '#e2e8f0',
                            titleFont: { weight: '600', size: 12 },
                            bodyFont: { weight: '500', size: 13 },
                            padding: { x: 12, y: 8 },
                            cornerRadius: 6,
                            displayColors: false,
                            callbacks: {
                                title: function(ctx) {
                                    var d = new Date(ctx[0].label + 'T00:00:00');
                                    return d.toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' });
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            grid: { display: false },
                            border: { display: false },
                            ticks: { color: tickColor, font: { size: 10 }, maxRotation: 0, maxTicksLimit: 6, callback: function(v) { return fmtDate(this.getLabelForValue(v)); } }
                        },
                        y: {
                            beginAtZero: true,
                            border: { display: false },
                            grid: { color: gridColor },
                            ticks: { color: tickColor, font: { size: 10 }, padding: 6, maxTicksLimit: 5 }
                        }
                    }
                };

                // Commissions chart
                var cCanvas = document.getElementById('kb-commissions-chart');
                var cCtx = cCanvas.getContext('2d');
                var cGrad = cCtx.createLinearGradient(0, 0, 0, 220);
                cGrad.addColorStop(0, isDark ? 'rgba(5, 150, 105, 0.2)' : 'rgba(5, 150, 105, 0.15)');
                cGrad.addColorStop(1, 'rgba(5, 150, 105, 0.01)');

                var cOpts = JSON.parse(JSON.stringify(baseOpts));
                cOpts.plugins.tooltip.callbacks.label = function(ctx) {
                    return '{{ currency }} ' + ctx.parsed.y.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                };

                new Chart(cCanvas, {
                    type: 'line',
                    data: {
                        labels: commissionsData.map(function(d) { return d.date; }),
                        datasets: [{
                            data: commissionsData.map(function(d) { return parseFloat(d.total); }),
                            borderColor: '#059669', borderWidth: 2, backgroundColor: cGrad, fill: true, tension: 0.35,
                            pointRadius: 0, pointHoverRadius: 5, pointHoverBackgroundColor: '#059669',
                            pointHoverBorderColor: isDark ? '#1e293b' : '#fff', pointHoverBorderWidth: 2,
                        }]
                    },
                    options: cOpts
                });

                // Referrals chart
                var rCanvas = document.getElementById('kb-referrals-chart');
                var rCtx = rCanvas.getContext('2d');
                var rGrad = rCtx.createLinearGradient(0, 0, 0, 220);
                rGrad.addColorStop(0, isDark ? 'rgba(124, 58, 237, 0.2)' : 'rgba(124, 58, 237, 0.12)');
                rGrad.addColorStop(1, 'rgba(124, 58, 237, 0.01)');

                var rOpts = JSON.parse(JSON.stringify(baseOpts));
                rOpts.scales.y.ticks.stepSize = 1;

                new Chart(rCanvas, {
                    type: 'line',
                    data: {
                        labels: referralsData.map(function(d) { return d.date; }),
                        datasets: [{
                            data: referralsData.map(function(d) { return parseInt(d.total); }),
                            borderColor: '#7c3aed', borderWidth: 2, backgroundColor: rGrad, fill: true, tension: 0.35,
                            pointRadius: 0, pointHoverRadius: 5, pointHoverBackgroundColor: '#7c3aed',
                            pointHoverBorderColor: isDark ? '#1e293b' : '#fff', pointHoverBorderWidth: 2,
                        }]
                    },
                    options: rOpts
                });
            })();
        {% endjs %}

        {# ── Top Affiliates ──────────────────────── #}
        {% if topAffiliates|length %}
            <div class="kb-section" style="animation-delay: 0.35s;">
                <div class="kb-section__header">
                    <h3 class="kb-section__title">{{ 'reports.topAffiliates'|t('kickback') }}</h3>
                    <a href="{{ cpUrl('kickback/affiliates') }}" class="kb-section__link">{{ 'View all'|t('app') }}</a>
                </div>
                <table class="kb-table">
                    <thead>
                        <tr>
                            <th style="width: 40px;"></th>
                            <th>{{ 'common.name'|t('kickback') }}</th>
                            <th>{{ 'Code'|t('kickback') }}</th>
                            <th style="text-align: right;">{{ 'affiliate.field.lifetimeEarnings'|t('kickback') }}</th>
                            <th style="text-align: right;">{{ 'affiliateStatus.pending'|t('kickback') }}</th>
                            <th>{{ 'common.status'|t('kickback') }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for affiliate in topAffiliates %}
                            <tr>
                                <td style="text-align: center;">
                                    {% if loop.index == 1 %}
                                        <span class="kb-rank kb-rank--gold">1</span>
                                    {% elseif loop.index == 2 %}
                                        <span class="kb-rank kb-rank--silver">2</span>
                                    {% elseif loop.index == 3 %}
                                        <span class="kb-rank kb-rank--bronze">3</span>
                                    {% else %}
                                        <span class="kb-rank">{{ loop.index }}</span>
                                    {% endif %}
                                </td>
                                <td><a href="{{ affiliate.cpEditUrl }}">{{ affiliate.title }}</a></td>
                                <td><span class="kb-mono">{{ affiliate.referralCode }}</span></td>
                                <td class="kb-numeric" style="text-align: right;">{{ affiliate.lifetimeEarnings|currency(currency) }}</td>
                                <td class="kb-numeric" style="text-align: right;">{{ affiliate.pendingBalance|currency(currency) }}</td>
                                <td>
                                    <span class="kb-badge kb-badge--{{ affiliate.affiliateStatus }}">{{ affiliate.affiliateStatus|capitalize }}</span>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}

    </div>
{% endblock %}
